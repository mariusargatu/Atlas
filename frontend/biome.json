{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "ignore": ["src/api/generated/**", "dist/**", "coverage/**", "playwright-report/**"] },
  "organizeImports": { "enabled": true },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2, "lineWidth": 100 },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": { "recommended": true },
      "correctness": { "noUnusedImports": "error", "noUnusedVariables": "error" },
      "style": { "useImportType": "error", "useConst": "error" },
      "security": { "noDangerouslySetInnerHtml": "error" }
    }
  },
  "javascript": { "formatter": { "quoteStyle": "double", "trailingCommas": "all" } },
  "overrides": [
    {
      "include": ["**/*.test.{ts,tsx}", "tests-e2e/**"],
      "linter": { "rules": { "suspicious": { "noExplicitAny": "off" } } }
    }
  ]
}
