{
  "components": {
    "schemas": {
      "AuthOut": {
        "properties": {
          "access_token": {
            "title": "Access Token",
            "type": "string"
          },
          "customer_id": {
            "title": "Customer Id",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          }
        },
        "required": ["access_token", "customer_id", "name"],
        "title": "AuthOut",
        "type": "object"
      },
      "ChatBody": {
        "properties": {
          "message": {
            "title": "Message",
            "type": "string"
          },
          "thread_id": {
            "default": "default",
            "title": "Thread Id",
            "type": "string"
          }
        },
        "required": ["message"],
        "title": "ChatBody",
        "type": "object"
      },
      "ChatOut": {
        "properties": {
          "final_response": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Final Response"
          },
          "pending": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PendingOut"
              },
              {
                "type": "null"
              }
            ]
          },
          "result": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ResultOut"
              },
              {
                "type": "null"
              }
            ]
          },
          "thread_id": {
            "title": "Thread Id",
            "type": "string"
          },
          "type": {
            "title": "Type",
            "type": "string"
          }
        },
        "required": ["type", "thread_id"],
        "title": "ChatOut",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LabelIn": {
        "properties": {
          "critique": {
            "title": "Critique",
            "type": "string"
          },
          "role": {
            "default": "adjudicator",
            "title": "Role",
            "type": "string"
          },
          "trace_id": {
            "title": "Trace Id",
            "type": "string"
          },
          "verdict": {
            "title": "Verdict",
            "type": "string"
          }
        },
        "required": ["trace_id", "verdict", "critique"],
        "title": "LabelIn",
        "type": "object"
      },
      "LabelItemOut": {
        "properties": {
          "answer": {
            "title": "Answer",
            "type": "string"
          },
          "case_id": {
            "title": "Case Id",
            "type": "string"
          },
          "question": {
            "title": "Question",
            "type": "string"
          },
          "registry_facts": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/RegistryFactOut"
            },
            "title": "Registry Facts",
            "type": "array"
          },
          "retrieved_chunks": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/RetrievedChunkOut"
            },
            "title": "Retrieved Chunks",
            "type": "array"
          },
          "source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source"
          },
          "trace_id": {
            "title": "Trace Id",
            "type": "string"
          }
        },
        "required": ["case_id", "trace_id", "question", "answer"],
        "title": "LabelItemOut",
        "type": "object"
      },
      "LabelItemsOut": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/LabelItemOut"
            },
            "title": "Items",
            "type": "array"
          },
          "progress": {
            "$ref": "#/components/schemas/ProgressOut"
          }
        },
        "required": ["items", "progress"],
        "title": "LabelItemsOut",
        "type": "object"
      },
      "LabelOut": {
        "properties": {
          "progress": {
            "$ref": "#/components/schemas/ProgressOut"
          }
        },
        "required": ["progress"],
        "title": "LabelOut",
        "type": "object"
      },
      "LoginBody": {
        "properties": {
          "customer_id": {
            "title": "Customer Id",
            "type": "string"
          }
        },
        "required": ["customer_id"],
        "title": "LoginBody",
        "type": "object"
      },
      "PendingOut": {
        "properties": {
          "args": {
            "additionalProperties": true,
            "title": "Args",
            "type": "object"
          },
          "customer_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Customer Id"
          },
          "idempotency_key": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Idempotency Key"
          },
          "tool": {
            "title": "Tool",
            "type": "string"
          }
        },
        "required": ["tool", "args"],
        "title": "PendingOut",
        "type": "object"
      },
      "ProgressOut": {
        "properties": {
          "labeled": {
            "title": "Labeled",
            "type": "integer"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          }
        },
        "required": ["labeled", "total"],
        "title": "ProgressOut",
        "type": "object"
      },
      "RegistryFactOut": {
        "properties": {
          "fact_id": {
            "title": "Fact Id",
            "type": "string"
          },
          "value": {
            "title": "Value",
            "type": "string"
          }
        },
        "required": ["fact_id", "value"],
        "title": "RegistryFactOut",
        "type": "object"
      },
      "ResultOut": {
        "properties": {
          "applied": {
            "title": "Applied",
            "type": "boolean"
          },
          "reference": {
            "title": "Reference",
            "type": "string"
          }
        },
        "required": ["reference", "applied"],
        "title": "ResultOut",
        "type": "object"
      },
      "ResumeBody": {
        "properties": {
          "confirmation": {
            "title": "Confirmation",
            "type": "string"
          },
          "thread_id": {
            "title": "Thread Id",
            "type": "string"
          }
        },
        "required": ["thread_id", "confirmation"],
        "title": "ResumeBody",
        "type": "object"
      },
      "RetrievedChunkOut": {
        "properties": {
          "chunk_id": {
            "title": "Chunk Id",
            "type": "string"
          },
          "doc_id": {
            "title": "Doc Id",
            "type": "string"
          },
          "score": {
            "default": 0.0,
            "title": "Score",
            "type": "number"
          },
          "text": {
            "title": "Text",
            "type": "string"
          }
        },
        "required": ["doc_id", "chunk_id", "text"],
        "title": "RetrievedChunkOut",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": ["loc", "msg", "type"],
        "title": "ValidationError",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "Atlas",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/auth/login": {
      "post": {
        "description": "Demo sign in AS a seeded customer (no password). Real auth is out of scope.",
        "operationId": "login_auth_login_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Login"
      }
    },
    "/auth/refresh": {
      "post": {
        "operationId": "refresh_auth_refresh_post",
        "parameters": [
          {
            "in": "cookie",
            "name": "atlas_refresh",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Atlas Refresh"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Refresh"
      }
    },
    "/auth/step-up": {
      "post": {
        "description": "Step up authorization: elevate an authenticated read session to a short lived write token\nfor the turn that confirms an action. A production system gates this on re auth (password/MFA).\nThe demo elevates on a valid read token. The write scope is never minted at login.",
        "operationId": "step_up_auth_step_up_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthOut"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Step Up"
      }
    },
    "/chat": {
      "post": {
        "operationId": "chat_chat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Chat"
      }
    },
    "/chat/resume": {
      "post": {
        "operationId": "resume_chat_resume_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResumeBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Resume"
      }
    },
    "/labels": {
      "post": {
        "operationId": "post_label_labels_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LabelIn"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LabelOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Post Label"
      }
    },
    "/labels/items": {
      "get": {
        "operationId": "get_items_labels_items_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LabelItemsOut"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Items"
      }
    }
  }
}
