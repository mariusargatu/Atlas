# Atlas — local dev only. NEVER commit a real .env.
# The hermetic PR lane (`task test`) needs NO keys at all (everything is replayed/faked).
# Keys/providers are used only in the record/nightly (`task eval`) and red-team lanes.

# Provider for the gateway's live model (record/eval only — replay needs none). See harness/models.py.
MODEL_PROVIDER=ollama              # ollama | anthropic | openai
MODEL_ID=qwen2.5:7b                # ollama: qwen2.5:7b · anthropic: claude-sonnet-4-6 · openai: gpt-5.5
OLLAMA_BASE_URL=http://localhost:11434

ANTHROPIC_API_KEY=        # if MODEL_PROVIDER=anthropic — latest: Opus 4.8, Sonnet 4.6, Haiku 4.5
OPENAI_API_KEY=           # the judge (cross-family, ADR-004) or MODEL_PROVIDER=openai — latest: GPT-5.5
