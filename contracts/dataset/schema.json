{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.contracts/dataset/0.1.0",
  "x-contract-version": "0.1.0",
  "title": "Atlas dataset contract: one golden case",
  "type": "object",
  "required": ["case_id", "split", "origin", "intent", "answerable", "turns"],
  "additionalProperties": false,
  "properties": {
    "case_id": { "type": "string" },
    "split": { "enum": ["dev", "test"] },
    "origin": { "enum": ["authored", "synthetic", "promoted"] },
    "candidate_source": { "type": ["string", "null"] },
    "source_trace_id": { "type": ["string", "null"] },
    "intent": { "type": "string" },
    "hop_count": { "type": "integer", "minimum": 0 },
    "doc_type": { "type": "string" },
    "adversarial_class": { "type": ["string", "null"] },
    "failure_class": { "type": ["string", "null"] },
    "answerable": { "type": "boolean" },
    "expected_doc_ids": { "type": "array", "items": { "type": "string" } },
    "expected_tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool"],
        "additionalProperties": false,
        "properties": {
          "tool": { "type": "string" },
          "args": { "type": "object" }
        }
      }
    },
    "expected_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fact_id"],
        "additionalProperties": false,
        "properties": {
          "fact_id": { "type": "string" },
          "value": {}
        }
      }
    },
    "refusal_class": { "type": ["string", "null"] },
    "customer_id": {
      "type": ["string", "null"],
      "description": "The signed-in session identity this case runs under. Optional: a factoid case is identity-independent and any session answers it identically. Required in practice for any case whose end_state asserts account state or whose expected_tool_calls name a write tool."
    },
    "persona": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "style": { "type": "string" }
      }
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["user"],
        "additionalProperties": false,
        "properties": {
          "user": { "type": "string" },
          "checkpoint": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "expected_intent": { "type": "string" },
              "expected_tool_calls": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["tool"],
                  "additionalProperties": false,
                  "properties": {
                    "tool": { "type": "string" },
                    "args": { "type": "object" }
                  }
                }
              },
              "note": { "type": "string" }
            }
          }
        }
      }
    },
    "end_state": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "account_assertions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "equals"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "equals": {}
            }
          }
        }
      }
    }
  }
}
